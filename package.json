{
  "name": "m365-copilot-adoption-command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "cf:export-data": "python3 scripts/export_cloudflare_data.py",
    "cf:prepare": "npm run cf:export-data && npm run build",
    "cf:check": "npm run cf:prepare && npx wrangler deploy --dry-run",
    "cf:deploy": "npm run cf:prepare && npx wrangler deploy"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.81.0"
  }
}
